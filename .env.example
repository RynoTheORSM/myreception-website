# Supabase — same project as my-reception-hub. Public-safe values
# (publishable/anon key); row access is governed by RLS.
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<publishable-anon-key>"

# Cloudflare Turnstile site key (public by design; the secret key lives in
# Supabase Edge Function secrets as TURNSTILE_SECRET_KEY).
VITE_TURNSTILE_SITE_KEY="<turnstile-site-key>"
